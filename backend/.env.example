# --- MongoDB ---
# Get this free from https://www.mongodb.com/cloud/atlas
# 1. Create free account -> Create free (M0) cluster
# 2. Database Access -> create a DB user (username + password)
# 3. Network Access -> Add IP -> Allow access from anywhere (0.0.0.0/0) for dev
# 4. Connect -> Drivers -> copy the connection string, replace <password>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-fit?retryWrites=true&w=majority

# --- JWT ---
# Any long random string, e.g. generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# --- Gemini AI (for plan generation, needed in Phase 3) ---
# Get free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- ExerciseDB (for exercise data, needed in Phase 3) ---
# Get free key from https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
EXERCISEDB_API_KEY=

PORT=5000
